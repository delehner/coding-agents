# =============================================================================
# Coding Agents Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Authentication ---

# Anthropic API key for Claude Code (pay-per-token via console.anthropic.com).
# Leave BLANK if you use a Claude Max subscription — the CLI will use your
# Max auth automatically. Only set this if you want API credits instead.
ANTHROPIC_API_KEY=

# Optional: Claude subscription OAuth token for containerized/headless runs.
# Generate with: claude setup-token
# Use this when Claude Max browser login does not propagate into Dev Containers.
CLAUDE_CODE_OAUTH_TOKEN=

# GitHub personal access token (or use `gh auth login`)
GITHUB_TOKEN=

# --- Claude Code Settings ---

# Default model (cost-sensitive default: sonnet)
CLAUDE_MODEL=sonnet

# Optional per-agent model overrides (falls back to CLAUDE_MODEL)
ARCHITECT_MODEL=
DESIGNER_MODEL=
MIGRATION_MODEL=
DEVELOPER_MODEL=
ACCESSIBILITY_MODEL=
TESTER_MODEL=
PERFORMANCE_MODEL=
SECOPS_MODEL=
DEPENDENCY_MODEL=
INFRASTRUCTURE_MODEL=
DEVOPS_MODEL=
ROLLBACK_MODEL=
DOCUMENTATION_MODEL=
REVIEWER_MODEL=

# Maximum iterations per agent Ralph Loop (default: 10)
PIPELINE_MAX_ITERATIONS=10

# Allowed tools for Claude Code headless mode
# Comma-separated list. Default allows file operations and shell.
CLAUDE_ALLOWED_TOOLS=Edit,Write,Bash,Read,MultiEdit

# --- Pipeline Defaults ---

# Default base branch for PRs (default: main)
DEFAULT_BASE_BRANCH=main

# Working directory for cloned repos (default: /tmp/coding-agents-work)
PIPELINE_WORK_DIR=/tmp/coding-agents-work

# Whether to clean up working directory after PR creation (default: false)
PIPELINE_CLEANUP=false

# Run agents inside Dev Containers for isolation (default: true).
# Requires Docker and @devcontainers/cli. Use --no-devcontainer to override.
USE_DEVCONTAINER=true

# Auto-update CLAUDE.md in target repo after agents finish (default: true)
UPDATE_PROJECT_CONTEXT=true

# Agents whose reports are posted as PR comments after PR creation.
# Comma-separated list. Set to empty to disable evidence comments.
EVIDENCE_AGENTS=tester,performance,secops,dependency,infrastructure,devops

# Max concurrent PRD×repo pipelines when running in parallel (default: 4)
PIPELINE_MAX_PARALLEL=4

# --- Optional Integrations ---

# Notion integration token (for Notion MCP)
NOTION_TOKEN=

# Figma access token (for Figma MCP)
# Generate at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=

# Slack configuration (for Slack MCP)
# Requires a registered Slack app with OAuth. See https://docs.slack.dev/ai/mcp-server
SLACK_TEAM_ID=

# Jira configuration (for Jira MCP)
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Agent-Specific Overrides ---
# Override max iterations per agent (falls back to PIPELINE_MAX_ITERATIONS)
ARCHITECT_MAX_ITERATIONS=
DESIGNER_MAX_ITERATIONS=
MIGRATION_MAX_ITERATIONS=
DEVELOPER_MAX_ITERATIONS=
ACCESSIBILITY_MAX_ITERATIONS=
TESTER_MAX_ITERATIONS=
PERFORMANCE_MAX_ITERATIONS=
SECOPS_MAX_ITERATIONS=
DEPENDENCY_MAX_ITERATIONS=
INFRASTRUCTURE_MAX_ITERATIONS=
DEVOPS_MAX_ITERATIONS=
ROLLBACK_MAX_ITERATIONS=
DOCUMENTATION_MAX_ITERATIONS=
REVIEWER_MAX_ITERATIONS=

# --- Logging & Monitoring ---

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Log directory (default: ./logs)
LOG_DIR=./logs

# Verbose logging: show agent thinking, tool calls, and results.
# Generator scripts (generate-prd.sh, generate-context.sh) default to verbose.
# Pipeline agents (run-agent.sh) default to false; the ca CLI always enables it.
# Raw JSON events saved as .jsonl files; formatted output as .log files.
VERBOSE_LOGS=false

# Interactive mode: pause between agents and iterations for review (default: false)
# Allows operator to review progress, modify PRD/progress files, skip, or abort.
INTERACTIVE=false
